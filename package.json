{
  "name": "mxre",
  "version": "0.1.0",
  "description": "Rental listing data aggregation and analysis",
  "type": "module",
  "bin": {
    "mxre": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed-oklahoma.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^17.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "private": true
}
