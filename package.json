{
  "name": "mxre",
  "version": "0.1.0",
  "description": "Rental listing data aggregation and analysis",
  "type": "module",
  "bin": {
    "mxre": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed-oklahoma.ts",
    "ingest": "tsx scripts/ingest-county.ts",
    "rent-tracker:ingest": "tsx scripts/ingest-listings.ts",
    "geocode:zips": "tsx scripts/geocode-missing-zips.ts",
    "rent-tracker:match": "tsx scripts/match-listings.ts",
    "rent-tracker:scan": "tsx scripts/daily-listing-scan.ts",
    "ingest:all": "tsx scripts/ingest-all-states.ts",
    "health": "tsx scripts/health-check.ts",
    "report": "tsx scripts/data-coverage-report.ts",
    "backfill": "tsx scripts/backfill-missing-data.ts",
    "rent-tracker:fast": "tsx scripts/ingest-listings-fast.ts",
    "rent-tracker:rents": "tsx scripts/scrape-rents-bulk.ts",
    "link:mortgages": "tsx scripts/link-mortgage-records.ts",
    "compute:taxes": "tsx scripts/compute-oh-taxes.ts",
    "enrich:mortgages": "tsx scripts/enrich-mortgage-amounts.ts",
    "reingest:shapefile": "tsx scripts/reingest-fairfield-shapefile.ts",
    "api": "tsx src/api/server.ts",
    "verify:liens": "tsx scripts/verify-liens.ts",
    "lookup:liens": "tsx scripts/lookup-liens-by-owner.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.49.1",
    "canvas": "^3.2.3",
    "csv-parse": "^6.2.1",
    "dbffile": "^1.12.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "pdf-to-img": "^5.0.0",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-core": "^24.40.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "shapefile": "^0.6.6",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "private": true
}
