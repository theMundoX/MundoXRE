# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Protected API access.
# MXRE_API_KEY is a local/admin fallback. Use MXRE_CLIENT_API_KEYS for partner keys.
MXRE_API_KEY=local-dev-secret
MXRE_CLIENT_API_KEYS=[{"id":"buy_box_club_prod","key":"replace-with-long-random-secret","environment":"production","monthlyQuota":10000000}]
MXRE_API_PORT=3101

# Self-hosted VPS Postgres (required for apply-migration.ts and run-listings-overnight.sh)
DB_HOST=your-vps-ip-or-hostname
DB_PORT=5432
POSTGRES_PASSWORD=your-postgres-password

# Residential proxy pool for listing scrapers. Multiple URLs may be comma-separated.
# IPRoyal example:
# PROXY_URL=http://username:password_country-us@geo.iproyal.com:12321
PROXY_URL=http://username:password@proxy-host:port
PROXY_DATACENTER_URL=http://username:password@proxy-host:port

# Google Places API (Phase 3 — website discovery)
GOOGLE_PLACES_API_KEY=your-key-here
